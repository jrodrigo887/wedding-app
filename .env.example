# ========================================
# CONFIGURACOES DE AMBIENTE - EXEMPLO
# ========================================
# Copie este arquivo para .env e ajuste os valores

# API Configuration
VITE_API_BASE_URL=http://localhost:3000

# App Configuration
VITE_APP_NAME=Lista de Casamento
VITE_BRIDE_NAME=Noiva
VITE_GROOM_NAME=Noivo
VITE_WEDDING_DATE=2026-01-01

# PIX Configuration
VITE_PIX_KEY=seu_pix_aqui
VITE_PIX_URL=seu_codigo_pix_copia_e_cola
VITE_BENEFICIARY_NAME=Seu Nome Completo

# Google Sheets Integration
# 1. Crie uma planilha no Google Sheets
# 2. Va em Extensoes > Apps Script
# 3. Cole o codigo do arquivo google-apps-script.js
# 4. Publique como Web App (Implantar > Nova implantacao > Web app)
# 5. Cole a URL gerada abaixo
VITE_GOOGLE_SCRIPT_URL=
VITE_USE_GOOGLE_SHEETS=true

# Infinity Pay - Link na Bio (client-side, prefixo VITE_)
VITE_INFINITYPAY_LINK_NA_BIO=https://link.infinitepay.io/sua_tag?origin=link-na-bio

# Infinity Pay Checkout API (SERVER-SIDE, sem VITE_ - lidas pela serverless function)
# Lidas via process.env na funcao api/checkout-infinitepay.js
# Em dev local: o vercel dev injeta automaticamente do .env
# Em producao: configurar no painel Vercel > Settings > Environment Variables
INFINITYPAY_HANDLE=sua_infinitetag_sem_arroba
INFINITYPAY_REDIRECT_URL=http://localhost:5173/obrigado

# ========================================
# Supabase Integration (Recomendado)
# ========================================
# 1. Crie uma conta em https://supabase.com
# 2. Crie um novo projeto
# 3. Va em Settings > API para obter URL e anon key
# 4. Execute o SQL de criacao das tabelas (ver supabase/schema.sql)
VITE_USE_SUPABASE=true
VITE_SUPABASE_URL=https://seu-projeto.supabase.co
VITE_SUPABASE_ANON_KEY=sua_anon_key_aqui

# ========================================
# Email API (Hostinger SMTP)
# ========================================
# URL da API de envio de email hospedada na Hostinger
VITE_EMAIL_API_URL=https://notificacoes.rodrigoelisa.com.br/api/send-email
VITE_EMAIL_API_KEY=sua-chave-secreta-aqui

# Feature Flags
VITE_ENABLE_MOCK_API=false

# Check-in Configuration (Area Restrita)
# PIN validado SERVER-SIDE via api/checkin-auth.ts — NÃO usar prefixo VITE_
# Em produção: configurar no Vercel Dashboard > Settings > Environment Variables
CHECKIN_PIN=123456
CHECKIN_SESSION_SECRET=string-aleatoria-de-32-chars-hex

# Supabase Service Key (SERVER-SIDE para api/convite.ts — NÃO usar VITE_)
# Obter em: Supabase Dashboard > Project Settings > API > service_role key
SUPABASE_SERVICE_KEY=sua_service_role_key_aqui

# SUPABASE_URL server-side (mesmo valor do VITE_SUPABASE_URL, sem prefixo VITE_)
SUPABASE_URL=https://seu-projeto.supabase.co
