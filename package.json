    "qrcode": "^1.5.4",
    "tesseract.js": "^7.0.0",
    "vue": "^3.5.24",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@tailwindcss/postcss": "^4.1.18",
    "@testing-library/vue": "^8.1.0",
